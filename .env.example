# ------------------------------------------------------------------
# SECURESKIES Environment Variables Example
# Copy to .env and fill in real values.  .env is gitignored.
# ------------------------------------------------------------------

# --- MQTT (Broker) ---
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=team9
# Provide password via file (preferred) or directly (dev only):
MQTT_PASS_FILE=/etc/securing-skies/mqtt_secret
# MQTT_PASS=                          # fallback if file missing

# --- Dashboard / ML Inference ---
INFERENCE_INTERVAL=30
WINDOW_SECONDS=300
MIN_SAMPLES=20
CONTAMINATION=0.02

# --- Caddy / HTTPS ---
# CADDY_HTTPS_PORT=9443
